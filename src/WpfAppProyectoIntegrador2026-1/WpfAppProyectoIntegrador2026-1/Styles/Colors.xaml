<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- ===================================================== -->
    <!-- PRIMARY -->
    <!-- ===================================================== -->

    <SolidColorBrush x:Key="PrimaryColor"
                     Color="#2563EB"/>

    <SolidColorBrush x:Key="PrimaryHoverColor"
                     Color="#1D4ED8"/>

    <!-- ===================================================== -->
    <!-- SECONDARY -->
    <!-- ===================================================== -->

    <SolidColorBrush x:Key="SecondaryColor"
                     Color="#6B7280"/>

    <SolidColorBrush x:Key="SecondaryHoverColor"
                     Color="#4B5563"/>

    <!-- ===================================================== -->
    <!-- SUCCESS -->
    <!-- ===================================================== -->

    <SolidColorBrush x:Key="SuccessColor"
                     Color="#10B981"/>

    <SolidColorBrush x:Key="SuccessHoverColor"
                     Color="#059669"/>

    <!-- ===================================================== -->
    <!-- DANGER -->
    <!-- ===================================================== -->

    <SolidColorBrush x:Key="DangerColor"
                     Color="#EF4444"/>

    <SolidColorBrush x:Key="DangerHoverColor"
                     Color="#DC2626"/>

    <!-- ===================================================== -->
    <!-- WARNING -->
    <!-- ===================================================== -->

    <SolidColorBrush x:Key="WarningColor"
                     Color="#F59E0B"/>

    <SolidColorBrush x:Key="WarningHoverColor"
                     Color="#D97706"/>

    <!-- ===================================================== -->
    <!-- BACKGROUNDS -->
    <!-- ===================================================== -->

    <SolidColorBrush x:Key="MainBackground"
                     Color="#F3F4F6"/>

    <SolidColorBrush x:Key="CardBackground"
                     Color="White"/>

    <SolidColorBrush x:Key="SidebarBackground"
                     Color="#111827"/>

    <SolidColorBrush x:Key="SidebarHover"
                     Color="#374151"/>

    <!-- ===================================================== -->
    <!-- TEXT -->
    <!-- ===================================================== -->

    <SolidColorBrush x:Key="PrimaryText"
                     Color="#111827"/>

    <SolidColorBrush x:Key="SecondaryText"
                     Color="#6B7280"/>

    <SolidColorBrush x:Key="WhiteText"
                     Color="White"/>

    <!-- ===================================================== -->
    <!-- BORDER -->
    <!-- ===================================================== -->

    <SolidColorBrush x:Key="BorderColor"
                     Color="#D1D5DB"/>

</ResourceDictionary>