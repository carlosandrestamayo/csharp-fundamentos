<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- ===================================================== -->
    <!-- BORDER RADIUS -->
    <!-- ===================================================== -->

    <CornerRadius x:Key="DefaultCornerRadius">
        10
    </CornerRadius>

    <!-- ===================================================== -->
    <!-- PADDING -->
    <!-- ===================================================== -->

    <Thickness x:Key="DefaultPadding">
        15,5
    </Thickness>

    <!-- ===================================================== -->
    <!-- MARGIN -->
    <!-- ===================================================== -->

    <Thickness x:Key="DefaultMargin">
        5
    </Thickness>

    <!-- ===================================================== -->
    <!-- FONT -->
    <!-- ===================================================== -->

    <FontFamily x:Key="DefaultFont">
        Segoe UI
    </FontFamily>

</ResourceDictionary>