<Window x:Class="WpfAppProyectoIntegrador2026_1.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:WpfAppProyectoIntegrador2026_1"
        mc:Ignorable="d"

        Title="Sistema de Gestión"

        Height="700"
        Width="1200"

        Background="{StaticResource MainBackground}">

    <Grid>

        <!-- COLUMNAS -->
        <Grid.ColumnDefinitions>

            <!-- SIDEBAR -->
            <ColumnDefinition Width="240"/>

            <!-- CONTENIDO -->
            <ColumnDefinition Width="*"/>

        </Grid.ColumnDefinitions>

        <!-- ===================================================== -->
        <!-- SIDEBAR -->
        <!-- ===================================================== -->

        <Border Grid.Column="0"
                Background="{StaticResource SidebarBackground}">

            <Grid>

                <Grid.RowDefinitions>

                    <!-- HEADER -->
                    <RowDefinition Height="Auto"/>

                    <!-- MENÚ -->
                    <RowDefinition Height="*"/>

                    <!-- FOOTER -->
                    <RowDefinition Height="Auto"/>

                </Grid.RowDefinitions>

                <!-- ===================================================== -->
                <!-- HEADER -->
                <!-- ===================================================== -->

                <StackPanel Margin="25">

                    <TextBlock Text="MI SISTEMA"
                               Style="{StaticResource TitleText}"
                               Foreground="{StaticResource WhiteText}"/>

                    <TextBlock Text="Sistema Administrativo"
                               Style="{StaticResource SubtitleText}"
                               Foreground="{StaticResource SecondaryText}"
                               Margin="0,5,0,0"/>

                </StackPanel>

                <!-- ===================================================== -->
                <!-- MENÚ -->
                <!-- ===================================================== -->

                <StackPanel Grid.Row="1"
                            Margin="0,20,0,0">

                    <Button Content="🏠  Dashboard"
                            Style="{StaticResource MenuButton}"
                            Click="BtnDashboard_Click"/>

                    <Button Content="👥  Clientes"
                            Style="{StaticResource MenuButton}"
                            Click="BtnClientes_Click"/>

                    <Button Content="📦  Materiales"
                            Style="{StaticResource MenuButton}"
                            Click="BtnMateriales_Click"/>

                    <Button Content="📄  Cotizaciones"
                            Style="{StaticResource MenuButton}"
                            Click="BtnCotizaciones_Click"/>

                    <Button Content="🧾  Facturas"
                            Style="{StaticResource MenuButton}"
                            Click="BtnFacturas_Click"/>
                    
                    <Button x:Name="btnUsuarios"
                            Content="🔐  Usuarios"
                            Style="{StaticResource MenuButton}"
                            Click="BtnUsuarios_Click"/>

                </StackPanel>

                <!-- ===================================================== -->
                <!-- FOOTER -->
                <!-- ===================================================== -->

                <Border Grid.Row="2"
                        Style="{StaticResource CardStyle}"
                        Margin="15"
                        Background="#1F2937"
                        BorderThickness="0">    

                    <StackPanel>

                        <!-- USUARIO -->
                        <TextBlock x:Name="txtUserName"
                                    Text="Usuario"
                                    Foreground="{StaticResource WhiteText}"
                                    FontWeight="SemiBold"
                                    FontSize="14"/>  

                        <!-- ROL -->
                        <TextBlock x:Name="txtUserRole"
                                    Text="Rol"
                                    Style="{StaticResource MutedText}"
                                    Foreground="{StaticResource SecondaryText}"
                                    Margin="0,5,0,15"/>  

                        <!-- LOGOUT -->
                        <Button x:Name="btnLogout"
                                Content="🚪 Cerrar Sesión"
                                Style="{StaticResource SecondaryButton}"
                                Click="BtnLogout_Click"/>

                    </StackPanel>

                </Border>
            </Grid>

        </Border>

        <!-- ===================================================== -->
        <!-- CONTENIDO -->
        <!-- ===================================================== -->

        <Grid Grid.Column="1"
              Background="{StaticResource MainBackground}">

            <Border Style="{StaticResource CardStyle}"
                    Margin="15">

                <ContentControl x:Name="Contenedor"/>

            </Border>

        </Grid>

    </Grid>

</Window>