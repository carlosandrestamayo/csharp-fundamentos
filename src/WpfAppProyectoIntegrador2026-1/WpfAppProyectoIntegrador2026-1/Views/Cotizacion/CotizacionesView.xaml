<UserControl x:Class="WpfAppProyectoIntegrador2026_1.Views.CotizacionesView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:WpfAppProyectoIntegrador2026_1.Views"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">
    <Grid>

        <Border Style="{StaticResource CardStyle}">

            <StackPanel>

                <TextBlock Text="Datos del Cliente"
                   Style="{StaticResource TitleText}"/>

                <!-- CLIENTE -->
                <TextBlock Text="Cliente"
                   Style="{StaticResource LabelText}"/>

                <ComboBox x:Name="cbClientes"
                  Style="{StaticResource ModernComboBox}"
                  SelectionChanged="CbClientes_SelectionChanged"/>

                <!-- IDENTIFICACIÓN -->
                <TextBlock Text="Identificación"
                   Style="{StaticResource LabelText}"/>

                <TextBox x:Name="txtIdentificacion"
                 IsReadOnly="True"
                 Style="{StaticResource ModernTextBox}"/>

                <!-- TELÉFONO -->
                <TextBlock Text="Teléfono"
                   Style="{StaticResource LabelText}"/>

                <TextBox x:Name="txtTelefono"
                 IsReadOnly="True"
                 Style="{StaticResource ModernTextBox}"/>

                <!-- CORREO -->
                <TextBlock Text="Correo"
                   Style="{StaticResource LabelText}"/>

                <TextBox x:Name="txtCorreo"
                 IsReadOnly="True"
                 Style="{StaticResource ModernTextBox}"/>

            </StackPanel>

        </Border>

    </Grid>
</UserControl>
