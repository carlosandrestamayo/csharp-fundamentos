<Window x:Class="WpfAppProyectoIntegrador2026_1.Views.Materiales.EditMaterialWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:WpfAppProyectoIntegrador2026_1.Views.Materiales"
        mc:Ignorable="d"
        Title=""
        Width="540"
        Height="550"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterScreen">

    <Grid Margin="20">

        <Border Background="{StaticResource CardBackground}"
                CornerRadius="15"
                Padding="25">

            <Grid>

                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <StackPanel Margin="0,0,0,25">

                    <TextBlock Text="Editar Material"
                               FontSize="30"
                               FontWeight="Bold"
                               Foreground="{StaticResource PrimaryText}"/>

                    <TextBlock Text="Actualizar información del material"
                               Margin="0,5,0,0"
                               FontSize="14"
                               Foreground="{StaticResource SecondaryText}"/>

                </StackPanel>

                <TextBox x:Name="txtNombre"
                         Grid.Row="1"
                         Width="420"
                         HorizontalAlignment="Left"
                         Tag="Nombre del material"
                         Style="{StaticResource ModernTextBox}"/>

                <TextBox x:Name="txtPrecioUnidad"
                         Grid.Row="2"
                         Width="420"
                         HorizontalAlignment="Left"
                         Tag="Precio por m³"
                         Style="{StaticResource ModernTextBox}"/>

                <TextBox x:Name="txtDescripcion"
                         Grid.Row="3"
                         Width="420"
                         Height="120"
                         AcceptsReturn="True"
                         TextWrapping="Wrap"
                         VerticalScrollBarVisibility="Auto"
                         HorizontalAlignment="Left"
                         Tag="Descripción"
                         Style="{StaticResource ModernTextBox}"/>

                <CheckBox x:Name="chkActivo"
                            Grid.Row="4"
                            Content="Activo"
                            Style="{StaticResource ModernCheckBox}"/>
                
                
                <!--<CheckBox x:Name="chkEstado"
                          Grid.Row="4"
                          Content="Activo"
                          IsChecked="True"
                          Margin="0,5,0,0"
                          FontSize="14"
                          Foreground="{StaticResource PrimaryText}"/>-->

                <StackPanel Grid.Row="5"
                            Orientation="Horizontal"
                            HorizontalAlignment="Right"
                            Margin="0,25,0,0">

                    <Button Content="Cancelar"
                            Width="120"
                            Style="{StaticResource SecondaryButton}"
                            Click="BtnCancel_Click"/>

                    <Button Content="Guardar"
                            Width="120"
                            Margin="10,0,0,0"
                            Style="{StaticResource PrimaryButton}"
                            Click="BtnUpdate_Click"/>

                </StackPanel>

            </Grid>

        </Border>

    </Grid>

</Window>