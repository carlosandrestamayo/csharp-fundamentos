<Window x:Class="WpfAppProyectoIntegrador2026_1.Views.Authentication.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:WpfAppProyectoIntegrador2026_1.Views.Authentication"
        mc:Ignorable="d"
        Title="Login"

        Height="500"
        Width="450"

        ResizeMode="NoResize"

        WindowStartupLocation="CenterScreen"

        Background="{StaticResource MainBackground}">

    <Grid>

        <!-- CARD -->
        <Border Style="{StaticResource CardStyle}"

                Width="360"
                Height="380"

                HorizontalAlignment="Center"
                VerticalAlignment="Center">

            <StackPanel>

                <!-- TITLE -->
                <TextBlock Text="Iniciar Sesión"
                           Style="{StaticResource TitleText}"
                           HorizontalAlignment="Center"
                           Margin="0,10,0,30"/>

                <!-- USERNAME -->
                <TextBox x:Name="txtUsername"

                         Tag="Username"

                         Style="{StaticResource ModernTextBox}"

                         Margin="0,0,0,15"/>

                <!-- PASSWORD -->
                <PasswordBox x:Name="txtPassword"

                             Height="40"

                             FontSize="14"

                             Padding="10"

                             Margin="0,0,0,25"/>

                <!-- LOGIN BUTTON -->
                <Button Content="Ingresar"

                        Height="40"

                        Style="{StaticResource PrimaryButton}"

                        Click="BtnLogin_Click"/>

            </StackPanel>

        </Border>

    </Grid>

</Window>
