<UserControl x:Class="WpfAppProyectoIntegrador2026_1.Views.DashboardView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d"
             d:DesignHeight="450"
             d:DesignWidth="800">

    <Grid Background="{StaticResource MainBackground}">

        <Border Style="{StaticResource CardStyle}"
                Margin="15"
                Padding="20">

            <Grid>

                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0"
                           Text="Dashboard"
                           FontSize="35"
                           FontWeight="Bold"
                           Margin="10,0,0,20"
                           Foreground="{StaticResource PrimaryText}"/>

                <UniformGrid Grid.Row="1"
                             Columns="4"
                             Margin="0,0,0,20">

                    <Border Style="{StaticResource CardStyle}"
                            Margin="5">

                        <StackPanel Margin="15">

                            <TextBlock Text="👥 Clientes"
                                       FontSize="16"
                                       FontWeight="SemiBold"/>

                            <TextBlock x:Name="txtTotalClientes"
                                       Text="125"
                                       FontSize="32"
                                       FontWeight="Bold"
                                       Foreground="{StaticResource PrimaryColor}"
                                       Margin="0,10,0,0"/>

                        </StackPanel>

                    </Border>

                    <Border Style="{StaticResource CardStyle}"
                            Margin="5">

                        <StackPanel Margin="15">

                            <TextBlock Text="📦 Materiales"
                                       FontSize="16"
                                       FontWeight="SemiBold"/>

                            <TextBlock x:Name="txtTotalMateriales"
                                       Text="85"
                                       FontSize="32"
                                       FontWeight="Bold"
                                       Foreground="{StaticResource SuccessColor}"
                                       Margin="0,10,0,0"/>

                        </StackPanel>

                    </Border>

                    <Border Style="{StaticResource CardStyle}"
                            Margin="5">

                        <StackPanel Margin="15">

                            <TextBlock Text="📄 Cotizaciones"
                                       FontSize="16"
                                       FontWeight="SemiBold"/>

                            <TextBlock x:Name="txtTotalCotizaciones"
                                       Text="34"
                                       FontSize="32"
                                       FontWeight="Bold"
                                       Foreground="{StaticResource WarningColor}"
                                       Margin="0,10,0,0"/>

                        </StackPanel>

                    </Border>

                    <Border Style="{StaticResource CardStyle}"
                            Margin="5">

                        <StackPanel Margin="15">

                            <TextBlock Text="🧾 Facturas"
                                       FontSize="16"
                                       FontWeight="SemiBold"/>

                            <TextBlock x:Name="txtTotalFacturas"
                                       Text="18"
                                       FontSize="32"
                                       FontWeight="Bold"
                                       Foreground="{StaticResource DangerColor}"
                                       Margin="0,10,0,0"/>

                        </StackPanel>

                    </Border>

                </UniformGrid>

                <Border Grid.Row="2"
                        Style="{StaticResource CardStyle}"
                        Padding="15">

                    <StackPanel>

                        <TextBlock Text="Actividad Reciente"
                                   FontSize="20"
                                   FontWeight="Bold"
                                   Margin="0,0,0,15"/>

                        <ListBox BorderThickness="0">

                            <ListBoxItem Content="👤 Cliente Juan Pérez registrado"/>
                            <ListBoxItem Content="📦 Material Cemento actualizado"/>
                            <ListBoxItem Content="📄 Cotización #102 creada"/>
                            <ListBoxItem Content="🧾 Factura #205 emitida"/>

                        </ListBox>

                    </StackPanel>

                </Border>

            </Grid>

        </Border>

    </Grid>

</UserControl>