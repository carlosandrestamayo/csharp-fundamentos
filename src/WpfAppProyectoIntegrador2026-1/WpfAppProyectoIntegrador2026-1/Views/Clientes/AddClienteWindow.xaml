<Window x:Class="WpfAppProyectoIntegrador2026_1.Views.Clientes.AddClienteWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:WpfAppProyectoIntegrador2026_1.Views.Clientes"
        mc:Ignorable="d"
        Title="" Height="600" Width="540"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterScreen"   
        Background="{StaticResource MainBackground}">

    <Grid Margin="20">

        <!-- CARD -->
        <Border Background="{StaticResource CardBackground}"
                CornerRadius="15"
                Padding="25">

            <Grid>

                <Grid.RowDefinitions>

                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>

                </Grid.RowDefinitions>

                <!-- TÍTULO -->
                <StackPanel Margin="0,0,0,25">

                    <TextBlock Text="Agregar Cliente"
                               FontSize="30"
                               FontWeight="Bold"
                               Foreground="{StaticResource PrimaryText}"/>

                    <TextBlock Text="Registrar información del cliente"
                               Margin="0,5,0,0"
                               FontSize="14"
                               Foreground="{StaticResource SecondaryText}"/>

                </StackPanel>

                <!-- NOMBRE -->
                <StackPanel Grid.Row="1">

                    <TextBlock Text="Nombre"
                               Style="{StaticResource LabelText}"/>

                    <TextBox x:Name="txtNombre"
                         Width="420"
                         HorizontalAlignment="Left"
                         Tag="Nombre del cliente"
                         Style="{StaticResource ModernTextBox}"/>
                </StackPanel>

                <!-- IDENTIFICACIÓN -->
                <StackPanel Grid.Row="2">

                    <TextBlock Text="Identificación"
                               Style="{StaticResource LabelText}"/>
                    
                    <TextBox x:Name="txtIdentificacion"
                         Grid.Row="2"
                         Width="420"
                         HorizontalAlignment="Left"
                         Tag="Número de identificación"
                         Style="{StaticResource ModernTextBox}"/>
                
                </StackPanel>

                <!-- TELÉFONO -->
                <StackPanel Grid.Row="3">
                    
                    <TextBlock Text="Teléfono"
                           Style="{StaticResource LabelText}"/>
                
                    <TextBox x:Name="txtTelefono"
                         Width="420"
                         HorizontalAlignment="Left"
                         Tag="Número telefónico"
                         Style="{StaticResource ModernTextBox}"/>
                </StackPanel>


                <!-- CORREO -->
                <StackPanel Grid.Row="4">

                    <TextBlock Text="Correo"
                               Style="{StaticResource LabelText}"/>
                    
                    <TextBox x:Name="txtCorreo"
                         Grid.Row="4"
                         Width="420"
                         Height="40"
                         VerticalAlignment="Top"
                         HorizontalAlignment="Left"
                         Tag="Correo electrónico"
                         Style="{StaticResource ModernTextBox}"/>
                
                </StackPanel>

                <!-- BOTONES -->
                <StackPanel Grid.Row="5"
                            Orientation="Horizontal"
                            HorizontalAlignment="Right"
                            Margin="0,25,0,0">

                    <Button Content="Cancelar"
                            Width="120"
                            Style="{StaticResource SecondaryButton}"
                            Click="BtnCancel_Click"/>

                    <Button Content="Guardar"
                            Width="120"
                            Style="{StaticResource PrimaryButton}"
                            Click="BtnSave_Click"/>

                </StackPanel>

            </Grid>

        </Border>

    </Grid>

</Window>