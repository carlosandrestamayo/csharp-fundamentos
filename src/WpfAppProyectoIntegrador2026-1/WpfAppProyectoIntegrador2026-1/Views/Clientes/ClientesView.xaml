<UserControl x:Class="WpfAppProyectoIntegrador2026_1.Views.Clientes.ClientesView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:local="clr-namespace:WpfAppProyectoIntegrador2026_1.Views.Clientes"
             mc:Ignorable="d"
             d:DesignHeight="450"
             d:DesignWidth="800">

    <Grid Background="{StaticResource MainBackground}">

        <!-- CARD PRINCIPAL -->
        <Border Style="{StaticResource CardStyle}"

                Margin="15"

                Padding="20">

            <Grid>

                <!-- ===================================================== -->
                <!-- FILAS -->
                <!-- ===================================================== -->

                <Grid.RowDefinitions>

                    <!-- HEADER -->
                    <RowDefinition Height="Auto"/>

                    <!-- TABLA -->
                    <RowDefinition Height="*"/>

                </Grid.RowDefinitions>

                <!-- ===================================================== -->
                <!-- HEADER -->
                <!-- ===================================================== -->

                <Grid Margin="0,0,0,20">

                    <Grid.ColumnDefinitions>

                        <ColumnDefinition Width="*"/>

                        <ColumnDefinition Width="Auto"/>

                    </Grid.ColumnDefinitions>

                    <!-- BUSCADOR -->
                    <TextBox x:Name="txtSearch"

                             Width="320"

                             HorizontalAlignment="Left"

                             Tag="Buscar cliente..."

                             Style="{StaticResource SearchTextBox}"

                             TextChanged="TxtSearch_TextChanged"/>

                    <!-- BOTÓN -->
                    <Button Grid.Column="1"

                            Content="Agregar Cliente"

                            Width="170"

                            Style="{StaticResource PrimaryButton}"

                            Click="BtnAdd_Click"/>

                </Grid>

                <!-- ===================================================== -->
                <!-- TABLA -->
                <!-- ===================================================== -->

                <DataGrid x:Name="tableClientes"

                          Grid.Row="1"

                          CanUserAddRows="False"

                          IsReadOnly="True"

                          BorderThickness="0"

                          SelectionMode="Single">

                    <DataGrid.Columns>

                        <!-- ID -->
                        <DataGridTextColumn Header="ID"
                                            Binding="{Binding Id}"
                                            Width="220"/>

                        <!-- NOMBRE -->
                        <DataGridTextColumn Header="Nombre"
                                            Binding="{Binding Nombre}"
                                            Width="*"/>

                        <!-- IDENTIFICACIÓN -->
                        <DataGridTextColumn Header="Identificación"
                                            Binding="{Binding Identificacion}"
                                            Width="180"/>

                        <!-- TELÉFONO -->
                        <DataGridTextColumn Header="Teléfono"
                                            Binding="{Binding Telefono}"
                                            Width="150"/>

                        <!-- CORREO -->
                        <DataGridTextColumn Header="Correo"
                                            Binding="{Binding Correo}"
                                            Width="250"/>

                        <!-- ACCIONES -->
                        <DataGridTemplateColumn Header="Acciones"
                                                Width="120">

                            <DataGridTemplateColumn.CellTemplate>

                                <DataTemplate>

                                    <Button Content="Editar"

                                            Width="90"

                                            Style="{StaticResource GridButton}"

                                            Click="BtnEdit_Click"/>

                                </DataTemplate>

                            </DataGridTemplateColumn.CellTemplate>

                        </DataGridTemplateColumn>

                    </DataGrid.Columns>

                </DataGrid>

            </Grid>

        </Border>

    </Grid>

</UserControl>