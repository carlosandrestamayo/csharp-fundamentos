<Window x:Class="WpfAppProyectoIntegrador2026_1.Views.Usuarios.ChangePasswordWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"

        Title=""

        Height="800"
        Width="750"

        ResizeMode="NoResize"

        WindowStartupLocation="CenterScreen"

        Background="{StaticResource MainBackground}">

    <Grid Margin="20">

        <Border Style="{StaticResource CardStyle}">

            <Grid Margin="25">

                <Grid.RowDefinitions>

                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>

                </Grid.RowDefinitions>

                <!-- TÍTULO -->
                <StackPanel Margin="0,0,0,25">

                    <TextBlock Text="Restablecer Contraseña"
                               Style="{StaticResource TitleText}"/>

                    <TextBlock Text="Se generará una nueva contraseña temporal para el usuario."
                               Style="{StaticResource SubtitleText}"/>

                </StackPanel>

                <!-- NOMBRE -->
                <StackPanel Grid.Row="1">

                    <TextBlock Text="Nombre"
                               Style="{StaticResource LabelText}"/>

                    <TextBox x:Name="txtNombre"
                             Width="420"
                             IsReadOnly="True"
                             Style="{StaticResource ModernTextBox}"/>

                </StackPanel>

                <!-- IDENTIFICACIÓN -->
                <StackPanel Grid.Row="2">

                    <TextBlock Text="Identificación"
                               Style="{StaticResource LabelText}"/>

                    <TextBox x:Name="txtIdentificacion"
                             Width="420"
                             IsReadOnly="True"
                             Style="{StaticResource ModernTextBox}"/>

                </StackPanel>

                <!-- USERNAME -->
                <StackPanel Grid.Row="3">

                    <TextBlock Text="Username"
                               Style="{StaticResource LabelText}"/>

                    <TextBox x:Name="txtUsername"
                             Width="420"
                             IsReadOnly="True"
                             Style="{StaticResource ModernTextBox}"/>

                </StackPanel>

                <!-- PASSWORD -->
                <StackPanel Grid.Row="4">

                    <TextBlock Text="Contraseña Temporal"
                               Style="{StaticResource LabelText}"/>

                    <TextBox x:Name="txtPassword"
                             Width="420"
                             IsReadOnly="True"
                             Style="{StaticResource ModernTextBox}"/>

                </StackPanel>

                <!-- INFORMACIÓN -->
                <Border Grid.Row="5"
                        Margin="0,15,0,0"
                        Padding="15"
                        Background="#FEF3C7"
                        CornerRadius="8">

                    <TextBlock TextWrapping="Wrap"
                               Foreground="#92400E"
                               Text="La contraseña fue generada automáticamente. Entréguesela al usuario para que pueda acceder nuevamente al sistema." />

                </Border>

                <!-- BOTONES -->
                <StackPanel Grid.Row="6"
                            Orientation="Horizontal"
                            HorizontalAlignment="Right"
                            Margin="0,20,0,0">

                    <Button Content="Generar Nueva"
                            Width="140"
                            Style="{StaticResource SecondaryButton}"
                            Click="BtnGeneratePassword_Click"/>

                    <Button Content="Cancelar"
                            Width="120"
                            Style="{StaticResource SecondaryButton}"
                            Click="BtnCancel_Click"/>

                    <Button Content="Restablecer"
                            Width="120"
                            Style="{StaticResource PrimaryButton}"
                            Click="BtnSave_Click"/>

                </StackPanel>

            </Grid>

        </Border>

    </Grid>

</Window>