<Window x:Class="WpfAppProyectoIntegrador2026_1.Views.Authentication.ChangeMyPasswordWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"

        Title=""

        Height="750"
        Width="650"

        ResizeMode="NoResize"

        WindowStartupLocation="CenterScreen"

        Background="{StaticResource MainBackground}">

    <Grid Margin="20">

        <Border Style="{StaticResource CardStyle}">

            <Grid Margin="25">

                <Grid.RowDefinitions>

                    <RowDefinition Height="Auto"/>

                    <RowDefinition Height="Auto"/>

                    <RowDefinition Height="Auto"/>

                    <RowDefinition Height="Auto"/>

                    <RowDefinition Height="Auto"/>

                    <RowDefinition Height="Auto"/>

                    <RowDefinition Height="*"/>

                    <RowDefinition Height="Auto"/>

                </Grid.RowDefinitions>

                <!-- TÍTULO -->
                <StackPanel Margin="0,0,0,25">

                    <TextBlock Text="Cambiar Contraseña"
                               Style="{StaticResource TitleText}"/>

                    <TextBlock Text="Actualice su contraseña de acceso al sistema."
                               Style="{StaticResource SubtitleText}"/>

                </StackPanel>

                <!-- USERNAME -->
                <StackPanel Grid.Row="1"
                            Margin="0,0,0,10">

                    <TextBlock Text="Usuario"
                               Style="{StaticResource LabelText}"/>

                    <TextBox x:Name="txtUsername"
                             IsReadOnly="True"
                             Style="{StaticResource ModernTextBox}"/>

                </StackPanel>

                <!-- PASSWORD ACTUAL -->
                <StackPanel Grid.Row="2"
                            Margin="0,0,0,10">

                    <TextBlock Text="Contraseña Actual"
                               Style="{StaticResource LabelText}"/>

                    <PasswordBox x:Name="txtCurrentPassword"
                                 Style="{StaticResource ModernPasswordBox}"/>

                </StackPanel>

                <!-- NUEVA PASSWORD -->
                <StackPanel Grid.Row="3"
                            Margin="0,0,0,10">

                    <TextBlock Text="Nueva Contraseña"
                               Style="{StaticResource LabelText}"/>

                    <Grid>

                        <Grid.ColumnDefinitions>

                            <ColumnDefinition Width="*"/>

                            <ColumnDefinition Width="170"/>

                        </Grid.ColumnDefinitions>

                        <PasswordBox x:Name="txtNewPassword"
                                     Grid.Column="0"
                                     Style="{StaticResource ModernPasswordBox}"/>

                        <Button Grid.Column="1"
                                Content="🔄 Generar"
                                Height="40"
                                Margin="10,0,0,0"
                                VerticalAlignment="Top"
                                Style="{StaticResource SecondaryButton}"
                                Click="BtnGeneratePassword_Click"/>

                    </Grid>

                </StackPanel>

                <!-- PASSWORD GENERADA -->
                <StackPanel Grid.Row="4"
                            Margin="0,0,0,10">

                    <TextBlock x:Name="lblGeneratedPassword"
                               Visibility="Collapsed"
                               Foreground="{StaticResource SecondaryText}"
                               FontSize="12"
                               TextWrapping="Wrap"/>

                </StackPanel>

                <!-- CONFIRM PASSWORD -->
                <StackPanel Grid.Row="5"
                            Margin="0,0,0,10">

                    <TextBlock Text="Confirmar Contraseña"
                               Style="{StaticResource LabelText}"/>

                    <PasswordBox x:Name="txtConfirmPassword"
                                 Style="{StaticResource ModernPasswordBox}"/>

                </StackPanel>

                <!-- REGLAS -->
                <Border Grid.Row="6"
                        Margin="0,10,0,0"
                        Padding="15"
                        Background="#DBEAFE"
                        CornerRadius="8">

                    <TextBlock TextWrapping="Wrap"
                               Foreground="#1E3A8A"
                               Text="La contraseña debe tener mínimo 8 caracteres, una letra mayúscula, un número y un carácter especial."/>

                </Border>

                <!-- BOTONES -->
                <StackPanel Grid.Row="7"
                            Orientation="Horizontal"
                            HorizontalAlignment="Right"
                            Margin="0,20,0,0">

                    <Button Content="Cancelar"
                            Width="120"
                            Style="{StaticResource DangerButton}"
                            Click="BtnCancel_Click"/>

                    <Button Content="Guardar"
                            Width="120"
                            Style="{StaticResource PrimaryButton}"
                            Click="BtnSave_Click"/>

                </StackPanel>

            </Grid>

        </Border>

    </Grid>

</Window>