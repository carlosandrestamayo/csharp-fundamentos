<Window x:Class="WpfAppProyectoIntegrador2026_1.Views.Usuarios.AddUsuarioWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"

        Title=""

        Height="Auto"
        Width="550"

        ResizeMode="NoResize"

        WindowStartupLocation="CenterScreen"

        Background="{StaticResource MainBackground}">

    <Grid Margin="20">

        <Border Style="{StaticResource CardStyle}">

            <Grid Margin="15">

                <Grid.RowDefinitions>

                    <RowDefinition Height="Auto"/>

                    <RowDefinition Height="Auto"/>

                    <RowDefinition Height="Auto"/>

                    <RowDefinition Height="Auto"/>

                    <RowDefinition Height="Auto"/>

                    <RowDefinition Height="Auto"/>

                    <RowDefinition Height="*"/>

                    <RowDefinition Height="Auto"/>

                </Grid.RowDefinitions>

                <!-- TÍTULO -->
                <StackPanel Margin="0,0,0,25">

                    <TextBlock Text="Crear Usuario"
                               Style="{StaticResource TitleText}"/>

                    <TextBlock Text="Registrar acceso al sistema"
                               Style="{StaticResource SubtitleText}"/>

                </StackPanel>

                <!-- CLIENTE -->
                <StackPanel Grid.Row="1">

                    <TextBlock Text="Cliente"
                               Style="{StaticResource LabelText}"/>

                    <Button Content="Buscar Cliente"
                            Width="180"
                            HorizontalAlignment="Left"
                            Style="{StaticResource SecondaryButton}"
                            Click="BtnSearchCliente_Click"/>

                </StackPanel>

                <!-- NOMBRE -->
                <StackPanel Grid.Row="2">

                    <TextBlock Text="Nombre"
                               Style="{StaticResource LabelText}"/>

                    <TextBox x:Name="txtNombre"
                             Width="390"
                             IsReadOnly="True"
                             Style="{StaticResource ModernTextBox}"/>

                </StackPanel>

                <!-- IDENTIFICACIÓN -->
                <StackPanel Grid.Row="3">

                    <TextBlock Text="Identificación"
                               Style="{StaticResource LabelText}"/>

                    <TextBox x:Name="txtIdentificacion"
                             Width="390"
                             IsReadOnly="True"
                             Style="{StaticResource ModernTextBox}"/>

                </StackPanel>

                <!-- USERNAME -->
                <StackPanel Grid.Row="4">

                    <TextBlock Text="Username"
                               Style="{StaticResource LabelText}"/>

                    <TextBox x:Name="txtUsername"
                             Width="390"
                             IsReadOnly="True"
                             Style="{StaticResource ModernTextBox}"/>

                </StackPanel>

                <!-- PASSWORD -->
                <StackPanel Grid.Row="5">

                    <TextBlock Text="Contraseña"
                               Style="{StaticResource LabelText}"/>

                    <TextBox x:Name="txtPassword"
                             Width="390"
                             IsReadOnly="True"
                             Style="{StaticResource ModernTextBox}"/>

                </StackPanel>

                <!-- BOTONES -->
                <StackPanel Grid.Row="7"
                            Orientation="Horizontal"
                            HorizontalAlignment="Right"
                            Margin="0,20,0,0">

                    <Button Content="Cancelar"
                            Width="120"
                            Style="{StaticResource SecondaryButton}"
                            Click="BtnCancel_Click"/>

                    <Button Content="Guardar"
                            Width="120"
                            Style="{StaticResource PrimaryButton}"
                            Click="BtnSave_Click"/>

                </StackPanel>

            </Grid>

        </Border>

    </Grid>

</Window>