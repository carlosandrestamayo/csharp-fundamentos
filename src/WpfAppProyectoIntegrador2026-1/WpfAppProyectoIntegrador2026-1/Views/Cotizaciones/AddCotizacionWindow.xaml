<Window x:Class="WpfAppProyectoIntegrador2026_1.Views.Cotizaciones.AddCotizacionWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:WpfAppProyectoIntegrador2026_1.Views.Cotizaciones"
        mc:Ignorable="d"
        Title=""
        Width="1000"
        Height="700"
        
        WindowStartupLocation="CenterScreen">

    <Grid Background="{StaticResource MainBackground}">

        <Border Style="{StaticResource CardStyle}"
                Margin="20"
                Padding="25">

            <Grid>

                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- TÍTULO -->

                <StackPanel Margin="0,0,0,25">

                    <TextBlock Text="Nueva Cotización"
                               FontSize="30"
                               FontWeight="Bold"
                               Foreground="{StaticResource PrimaryText}"/>

                    <TextBlock Text="Registrar una nueva cotización"
                               Margin="0,5,0,0"
                               FontSize="14"
                               Foreground="{StaticResource SecondaryText}"/>

                </StackPanel>

                <!-- DATOS GENERALES -->

                <Border Grid.Row="1"
        Margin="0,0,0,20"
        Padding="15"
        BorderBrush="{StaticResource BorderColor}"
        BorderThickness="1"
        CornerRadius="10">

                    <Grid>

                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <TextBlock Text="Información del Cliente"
                   FontSize="18"
                   FontWeight="SemiBold"
                   Margin="0,0,0,15"
                   Foreground="{StaticResource PrimaryText}"/>

                        <Grid Grid.Row="1">

                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <TextBox x:Name="txtClienteNombre"
                                     Grid.Row="0"
                                     Grid.Column="0"
                                     Margin="0,0,10,10"
                                     Tag="Nombre"
                                     IsReadOnly="True"
                                     Style="{StaticResource ModernTextBox}"/>

                            <TextBox x:Name="txtClienteIdentificacion"
                                     Grid.Row="0"
                                     Grid.Column="1"
                                     Margin="0,0,10,10"
                                     Tag="Identificación"
                                     IsReadOnly="True"
                                     Style="{StaticResource ModernTextBox}"/>   

                            <TextBox x:Name="txtClienteTelefono"
                                       Grid.Row="1"
                                       Grid.Column="0"
                                       Margin="0,0,10,0"
                                       Tag="Teléfono"
                                       IsReadOnly="True"
                                       Style="{StaticResource ModernTextBox}"/>

                            <TextBox x:Name="txtClienteCorreo"
                                         Grid.Row="1"
                                         Grid.Column="1"
                                         Margin="0,0,10,0"
                                         Tag="Correo"
                                         IsReadOnly="True"
                                         Style="{StaticResource ModernTextBox}"/>   

                            <Button Grid.RowSpan="2"
                    Grid.Column="2"
                    Width="160"
                    Content="Buscar Cliente"
                    Style="{StaticResource PrimaryButton}"
                    Click="BtnSearchClient_Click"/>

                        </Grid>

                    </Grid>

                </Border>

                <!-- DETALLES -->

                <Grid Grid.Row="2">

                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <Grid Margin="0,0,0,15">

                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <TextBlock Text="Materiales"
                                   FontSize="18"
                                   FontWeight="SemiBold"
                                   VerticalAlignment="Center"/>

                        <Button Grid.Column="1"
                                Width="170"
                                Content="Agregar Material"
                                Style="{StaticResource PrimaryButton}"
                                Click="BtnAddMaterial_Click"/>

                    </Grid>

                    <DataGrid x:Name="tableDetalles"
                              Grid.Row="1"
                              AutoGenerateColumns="False"
                              CanUserAddRows="False"
                              IsReadOnly="True"
                              BorderThickness="0"
                              SelectionMode="Single"
                              HorizontalGridLinesBrush="#E5E7EB">

                        <DataGrid.Columns>

                            <DataGridTextColumn Header="Material"
                                                Binding="{Binding Material.Nombre}"
                                                Width="*"/>

                            <DataGridTextColumn Header="Cantidad"
                                                Binding="{Binding Cantidad}"
                                                Width="120"/>

                            <DataGridTextColumn Header="Precio"
                                                Binding="{Binding PrecioUnidad}"
                                                Width="150"/>

                            <DataGridTextColumn Header="Subtotal"
                                                Binding="{Binding Subtotal}"
                                                Width="150"/>

                            <DataGridTemplateColumn Header="Acciones"
                                                    Width="120">

                                <DataGridTemplateColumn.CellTemplate>

                                    <DataTemplate>

                                        <Button Content="Eliminar"
                                                Width="90"
                                                Style="{StaticResource DangerButton}"
                                                Click="BtnDeleteDetail_Click"/>

                                    </DataTemplate>

                                </DataGridTemplateColumn.CellTemplate>

                            </DataGridTemplateColumn>

                        </DataGrid.Columns>

                    </DataGrid>

                </Grid>

                <!-- TOTALES -->

                <Grid Grid.Row="3"
                      Margin="0,20,0,0">

                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="220"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="1">

                        <TextBlock x:Name="txtTotal"
                                   Text="Total: $0"
                                   FontSize="24"
                                   FontWeight="Bold"
                                   HorizontalAlignment="Right"
                                   Foreground="{StaticResource PrimaryText}"/>

                        <StackPanel Orientation="Horizontal"
                                    HorizontalAlignment="Right"
                                    Margin="0,20,0,0">

                            <Button Content="Cancelar"
                                    Width="120"
                                    Style="{StaticResource SecondaryButton}"
                                    Click="BtnCancel_Click"/>

                            <Button Content="Guardar"
                                    Width="120"
                                    Margin="10,0,0,0"
                                    Style="{StaticResource PrimaryButton}"
                                    Click="BtnSave_Click"/>

                        </StackPanel>

                    </StackPanel>

                </Grid>

            </Grid>

        </Border>

    </Grid>

</Window>